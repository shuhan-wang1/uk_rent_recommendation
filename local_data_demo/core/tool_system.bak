# My Custom Tool Implementation - SearchPropertiesTool
# ============================================================================

class SearchPropertiesTool(BaseTool):
    """
    Search for properties based on location and budget
    """
    
    def __init__(self):
        super().__init__(
            name="search_properties",
            description="搜索符合条件的房源",
            parameters={
                'type': 'object',
                'properties': {
                    'location': {'type': 'string', 'description': '地点（如UCL、King\'s College）'},
                    'max_budget': {'type': 'integer', 'description': '最大预算（英镑）'}
                },
                'required': ['location', 'max_budget']
            },
            max_retries=2
        )
    
    async def execute(self, location: str, max_budget: int, **kwargs) -> ToolResult:
        """
        Execute property search
        """
        from .database_service import search_in_db  # 假设有个数据库服务模块
        
        if not location:
            return ToolResult(
                success=False,
                error="地点是必需的",
                tool_name=self.name
            )
        
        if max_budget <= 0:
            return ToolResult(
                success=False,
                error="预算必须大于0",
                tool_name=self.name
            )
        
        print(f"  [SEARCH_PROPERTIES] Searching properties in {location} with max budget {max_budget}...")
        
        # 你的搜索逻辑
        results = await search_in_db(location, max_budget)
        
        return ToolResult(
            success=True,
            data={'results': results, 'count': len(results)},
            tool_name=self.name
        )


# ============================================================================
# 更新工具注册表，包含自定义工具
# ============================================================================

def create_tool_registry() -> ToolRegistry:
    """
    Create and configure tool registry
    Returns ToolRegistry instance with all registered tools
    """
    registry = ToolRegistry()
    
    # Register supermarket search tool
    search_supermarket_tool = SearchSupermarketTool()
    registry.register(search_supermarket_tool)
    
    # Register property search tool
    search_properties_tool = SearchPropertiesTool()
    registry.register(search_properties_tool)
    
    return registry


from tool_system.base import ToolRegistry

# 创建注册中心
registry = ToolRegistry()

# 注册工具
registry.register(search_properties_tool)
registry.register(calculate_commute_tool)
registry.register(check_safety_tool)

from tool_system.function_calling import FunctionCalling
import asyncio

async def run_agent(user_query: str):
    # 初始化
    registry = create_tool_registry()
    fc = FunctionCalling(registry)
    
    # Agent 循环（可以循环多次）
    for turn in range(5):  # 最多5步
        print(f"\n=== 第 {turn+1} 步 ===")
        
        # 让 AI 决定做什么
        decision = fc.ask_ai_to_choose_tool(
            user_query,
            context={'observations': observations}
        )
        
        if decision['action'] == 'use_tool':
            # 执行工具
            tool_name = decision['tool_name']
            tool_params = decision['tool_params']
            
            result = await registry.execute_tool(tool_name, **tool_params)
            
            observations.append({
                'tool_name': tool_name,
                'success': result.success,
                'data': result.data,
                'error': result.error
            })
        
        elif decision['action'] == 'finish':
            # 任务完成
            print(f"✅ 最终答案: {decision['final_answer']}")
            break
        
        elif decision['action'] == 'clarify':
            # 需要澄清
            user_query = input(f"\n❓ {decision['question']}\n你: ")

# 运行
user_query = "Find me a flat near UCL, budget £1500, max 30 min commute to King's College"
asyncio.run(run_agent(user_query))
